# Resend API key (from the Refresh Portal Resend account, or a new one)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The verified sender. Must be on a domain verified in Resend (e.g. refresh.lucidbots.com).
RESEND_FROM_EMAIL="Refresh Builder <refresh@refresh.lucidbots.com>"

# Where submissions are emailed.
REFRESH_INBOX=refresh@lucidbots.com

# HubSpot private app token (crm.objects.contacts read + write).
# Used to write the configured plan/add-ons/total onto the contact record.
# Leave unset to disable the writeback (submissions still work).
HUBSPOT_TOKEN=
